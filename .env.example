# ═══════════════════════════════════════════════════
# Who.M.I 환경변수 설정 가이드
# ═══════════════════════════════════════════════════
# 이 파일을 .env.local로 복사하여 값을 채우세요:
#   cp .env.example .env.local
# ═══════════════════════════════════════════════════

# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── PortOne (포트원) 결제 ───
# 클라이언트용 (브라우저 노출 가능)
NEXT_PUBLIC_PORTONE_STORE_ID=store-xxxxxxxx-xxxx
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=channel-key-xxxxxxxx

# 서버용 (절대 클라이언트에 노출 금지!)
# 포트원 관리자 콘솔 → API Keys → V2 API Secret
PORTONE_API_SECRET=portone-api-secret-xxxxxxxx

# ─── OpenAI (AI 인사이트용, 선택사항) ───
OPENAI_API_KEY=sk-xxxxxxxx
